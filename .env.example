# Base URL of the Django API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public base URL of the production media host (Cloudflare R2 custom domain or
# pub-xxxx.r2.dev). Must match the API's R2_PUBLIC_DOMAIN. Leave unset in dev.
# NEXT_PUBLIC_MEDIA_URL=https://media.example.com

# ─── SEO ──────────────────────────────────────────────────────────────────────

# Canonical origin of the site — used for sitemap, robots.txt, JSON-LD, and
# all absolute URLs in metadata. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://aviral.me

# Google Search Console ownership verification token.
# Found at: Search Console → Settings → Ownership verification → HTML tag
# e.g. NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=abc123def456
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification token.
# Found at: Bing Webmaster → Settings → Verify → HTML meta tag content value
# e.g. NEXT_PUBLIC_BING_SITE_VERIFICATION=abc123def456
# NEXT_PUBLIC_BING_SITE_VERIFICATION=
